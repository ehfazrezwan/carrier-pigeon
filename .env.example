# ─────────────────────────────────────────────
# Required: admin auth
# ─────────────────────────────────────────────
ADMIN_PASSWORD=pick-a-strong-secret
SESSION_SECRET=run-openssl-rand-hex-32-to-generate

# ─────────────────────────────────────────────
# Database — pick ONE of the two below.
# If SUPABASE_URL is set, Supabase is used.
# Otherwise the app falls back to SQLite.
# You can also force a driver with DB_DRIVER=supabase|sqlite.
# ─────────────────────────────────────────────

# Option 1: Supabase (hosted Postgres — works on Vercel)
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Option 2: SQLite (a local file — works on a VPS or your laptop,
#                   but NOT on Vercel since serverless has no persistent disk)
# SQLITE_PATH=./data/carrier-pigeon.db
